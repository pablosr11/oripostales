# ── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get this after creating the webhook endpoint in Stripe Dashboard
# Endpoint URL: https://api.psiesta.com/api/webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...
# Price in cents (e.g. 1500 = €15.00)
STRIPE_PRICE_CENTS=1500
# Currency code (lowercase ISO 4217)
STRIPE_CURRENCY=eur

# ── Resend (https://resend.com) ──────────────────────────────────────────────
# 1. Sign up at resend.com (free tier: 3,000 emails/month)
# 2. Add & verify your sending domain (or use onboarding@resend.dev for testing)
# 3. Create an API key at resend.com/api-keys
RESEND_API_KEY=re_...
# The "From" address — must use a domain you've verified in Resend
RESEND_FROM=OriPostales <postales@psiesta.com>
# Where order notification emails are delivered (your personal inbox)
EMAIL_TO=you@gmail.com

# ── App ─────────────────────────────────────────────────────────────────────
PORT=3001
# Where the frontend lives (used for Stripe success/cancel URLs)
FRONTEND_URL=https://psiesta.com/postal
# Base URL for uploaded photos in notification emails
UPLOADS_BASE_URL=https://api.psiesta.com/uploads
